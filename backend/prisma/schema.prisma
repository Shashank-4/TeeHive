generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String               @id @default(uuid())
  email                   String               @unique
  name                    String
  password                String?
  tokenVersion            Int                  @default(0)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  payoutDetails           Json?
  artistNumber            Int?                 @unique
  authProvider            String               @default("LOCAL")
  behanceUrl              String?
  bio                     String?
  canResubmitVerification Boolean              @default(false)
  coverPhotoKey           String?
  coverPhotoUrl           String?
  displayName             String?              @unique
  /// Public storefront URL segment (lowercase); unique when set.
  artistSlug              String?              @unique
  displayPhotoKey         String?
  displayPhotoUrl         String?
  dribbbleUrl             String?
  googleId                String?              @unique
  instagramUrl            String?
  isAdmin                 Boolean              @default(false)
  isArtist                Boolean              @default(false)
  isEmailVerified         Boolean              @default(false)
  otpCode                 String?
  otpExpiresAt            DateTime?
  portfolioUrl            String?
  resetPasswordExpires    DateTime?
  resetPasswordToken      String?
  twitterUrl              String?
  verificationNote        String?
  verificationStatus      VerificationStatus   @default(UNVERIFIED)
  verifiedAt              DateTime?
  artistRating            Float                @default(0.0)
  reviewCount             Int                  @default(0)
  designs                 Design[]
  orders                  Order[]
  products                Product[]
  artistOrderItems        OrderItem[]          @relation("ArtistOrderItems")
  payoutMethods           ArtistPayoutMethod[] @relation("ArtistPayoutMethods")
  payoutMethodReviews     ArtistPayoutReview[] @relation("ArtistPayoutMethodReviews")
  payoutReviewsPerformed  ArtistPayoutReview[] @relation("PayoutMethodReviewedBy")
  artistSettlements       ArtistSettlement[]   @relation("ArtistSettlements")
  settlementsProcessed    ArtistSettlement[]   @relation("ArtistSettlementProcessedBy")
  customerReviews         Review[]             @relation("CustomerReviews")
  artistReviews           Review[]             @relation("ArtistReviews")
  returnClaims            OrderReturnClaim[]   @relation("CustomerReturnClaims")
  reviewedReturnClaims    OrderReturnClaim[]   @relation("ReturnClaimReviewedBy")
  adminAuditLogs          AdminAuditLog[]      @relation("AdminAuditLogs")
}

model Design {
  id              String       @id @default(uuid())
  title           String
  imageUrl        String
  fileKey         String       @unique
  status          DesignStatus @default(PENDING)
  rejectionReason String?
  artistId        String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  isDeleted       Boolean      @default(false)
  isRejected      Boolean      @default(false)
  designCode      String?      @unique
  artist          User         @relation(fields: [artistId], references: [id])
  products        Product[]
}

model Category {
  id        String  @id @default(uuid())
  name      String  @unique
  imageUrl  String?
  /// Display order when site category_sort_mode is "custom" (lower first).
  sortOrder Int     @default(0)
}

model SiteConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Product {
  id                 String           @id @default(uuid())
  name               String
  description        String?
  price              Float
  compareAtPrice     Float?
  tshirtColor        String
  stock              Int              @default(0)
  status             ProductStatus    @default(DRAFT)
  mockupImageUrl     String
  mockupFileKey      String?
  designId           String
  artistId           String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tags               String[]
  availableColors    String[]
  primaryColor       String           @default("")
  primaryView        String           @default("front")
  backMockupImageUrl String?
  backMockupFileKey  String?
  categories         String[]
  globalColors       GlobalColor[]
  /// Per-fabric hex → { front, back? } mockup URLs (JSON). Fallback: mockupImageUrl / backMockupImageUrl.
  colorMockups       Json?
  /// Curated “latest drops” on home / shop (max 10 published); toggled by admin.
  isLatestDrop       Boolean          @default(false)
  /// Persisted artist-side mockup editor state used to reopen draft products.
  draftEditorState   Json?
  stockStatus        StockStatus      @default(IN_STOCK)
  orderItems         OrderItem[]
  reviews            Review[]
  artist             User             @relation(fields: [artistId], references: [id])
  design             Design           @relation(fields: [designId], references: [id])
  variants           ProductVariant[]
}

model ProductVariant {
  id          String      @id @default(uuid())
  productId   String
  color       String
  size        String
  stockStatus StockStatus @default(IN_STOCK)
  stock       Int         @default(0)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, color, size])
}

model Order {
  id                    String                @id @default(uuid())
  userId                String
  subtotalAmount        Float                 @default(0)
  shippingAmount        Float                 @default(0)
  totalAmount           Float
  currency              String                @default("inr")
  status                OrderStatus           @default(PENDING)
  paymentStatusSnapshot PaymentStatus?
  paymentIntentId       String?               @unique
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  couponCode            String?
  discountAmount        Float                 @default(0)
  pricingVersion        Int                   @default(1)
  pricingSnapshot       Json?
  paymentVerifiedAt     DateTime?
  paidAt                DateTime?
  cancelledAt           DateTime?
  cancelReason          String?
  user                  User                  @relation(fields: [userId], references: [id])
  items                 OrderItem[]
  reviews               Review[]
  payment               Payment?
  webhookEvents         PaymentWebhookEvent[]
  shippingAddress       ShippingAddress?
  returnClaim           OrderReturnClaim?
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  discountPercent Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SpecialOffer {
  id              String   @id @default(uuid())
  title           String
  subtitle        String?
  categoryName    String
  discountPercent Float
  isVisible       Boolean  @default(false)
  ctaText         String   @default("SHOP COLLECTION")
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id                String  @id @default(uuid())
  orderId           String
  quantity          Int
  price             Float
  size              String
  color             String
  productId         String
  artistId          String?
  artistShareAmount Float   @default(0)
  platformFeeAmount Float   @default(0)
  pricingSnapshot   Json?
  artist            User?   @relation("ArtistOrderItems", fields: [artistId], references: [id])
  order             Order   @relation(fields: [orderId], references: [id])
  product           Product @relation(fields: [productId], references: [id])
}

model ShippingAddress {
  id         String  @id @default(uuid())
  orderId    String  @unique
  name       String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String
  phone      String?
  order      Order   @relation(fields: [orderId], references: [id])
}

model Payment {
  id                 String                @id @default(uuid())
  orderId            String                @unique
  amount             Float
  currency           String                @default("inr")
  status             PaymentStatus         @default(PENDING)
  provider           PaymentProvider       @default(RAZORPAY)
  paymentIntentId    String                @unique
  gatewayOrderId     String?               @unique
  gatewayPaymentId   String?               @unique
  gatewaySignature   String?
  paymentMethod      String?
  failureCode        String?
  failureDescription String?
  verifiedAt         DateTime?
  capturedAt         DateTime?
  refundedAmount     Float                 @default(0)
  refundReference    String?
  gatewayPayload     Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  order              Order                 @relation(fields: [orderId], references: [id])
  webhookEvents      PaymentWebhookEvent[]
}

model PaymentWebhookEvent {
  id              String                  @id @default(uuid())
  provider        PaymentProvider         @default(RAZORPAY)
  providerEventId String
  eventType       String
  signature       String?
  payload         Json
  payloadHash     String?
  status          WebhookProcessingStatus @default(RECEIVED)
  errorMessage    String?
  receivedAt      DateTime                @default(now())
  processedAt     DateTime?
  orderId         String?
  paymentId       String?
  order           Order?                  @relation(fields: [orderId], references: [id])
  payment         Payment?                @relation(fields: [paymentId], references: [id])

  @@unique([provider, providerEventId])
  @@index([orderId])
  @@index([paymentId])
  @@index([eventType, status])
}

model OrderReturnClaim {
  id                String            @id @default(uuid())
  orderId           String            @unique
  customerId        String
  reason            ReturnClaimReason
  status            ReturnClaimStatus @default(OPEN)
  description       String
  evidenceUrls      Json?
  evidenceKeys      Json?
  requestedAt       DateTime          @default(now())
  reviewedAt        DateTime?
  reviewNote        String?
  reviewedByAdminId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer          User              @relation("CustomerReturnClaims", fields: [customerId], references: [id])
  reviewedByAdmin   User?             @relation("ReturnClaimReviewedBy", fields: [reviewedByAdminId], references: [id])

  @@index([customerId, status])
  @@index([status, requestedAt])
}

model ArtistPayoutMethod {
  id                         String                   @id @default(uuid())
  artistId                   String
  methodType                 PayoutMethodType
  verificationStatus         PayoutVerificationStatus @default(DRAFT)
  upiId                      String?
  upiName                    String?
  bankAccountName            String?
  bankAccountNumberEncrypted String?
  bankAccountNumberLast4     String?
  bankIfsc                   String?
  bankName                   String?
  methodFingerprint          String?
  isDefault                  Boolean                  @default(false)
  isActive                   Boolean                  @default(true)
  submittedAt                DateTime?
  verifiedAt                 DateTime?
  rejectedAt                 DateTime?
  rejectionReason            String?
  verificationNotes          String?
  providerValidationId       String?
  providerValidationStatus   String?
  providerValidationMode     String?
  providerValidationReference String?
  providerContactId          String?
  providerFundAccountId      String?
  providerRegisteredName     String?
  providerNameMatchScore     Int?
  providerValidationReason   String?
  providerValidationPayload  Json?
  providerValidatedAt        DateTime?
  providerUtr               String?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  artist                     User                     @relation("ArtistPayoutMethods", fields: [artistId], references: [id])
  reviews                    ArtistPayoutReview[]
  settlements                ArtistSettlement[]

  @@unique([artistId, methodFingerprint])
  @@unique([providerValidationId])
  @@index([artistId, verificationStatus])
}

model ArtistPayoutReview {
  id              String             @id @default(uuid())
  payoutMethodId  String
  artistId        String
  reviewerAdminId String
  action          PayoutReviewAction
  note            String?
  createdAt       DateTime           @default(now())
  payoutMethod    ArtistPayoutMethod @relation(fields: [payoutMethodId], references: [id], onDelete: Cascade)
  artist          User               @relation("ArtistPayoutMethodReviews", fields: [artistId], references: [id])
  reviewerAdmin   User               @relation("PayoutMethodReviewedBy", fields: [reviewerAdminId], references: [id])

  @@index([payoutMethodId])
  @@index([artistId, createdAt])
}

model ArtistSettlement {
  id                 String                 @id @default(uuid())
  artistId           String
  payoutMethodId     String?
  amount             Float
  currency           String                 @default("inr")
  status             ArtistSettlementStatus @default(PENDING)
  periodStart        DateTime
  periodEnd          DateTime
  bankReference      String?
  notes              String?
  processedByAdminId String?
  processedAt        DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  artist             User                   @relation("ArtistSettlements", fields: [artistId], references: [id])
  payoutMethod       ArtistPayoutMethod?    @relation(fields: [payoutMethodId], references: [id])
  processedByAdmin   User?                  @relation("ArtistSettlementProcessedBy", fields: [processedByAdminId], references: [id])

  @@index([artistId, status])
  @@index([payoutMethodId])
}

enum VerificationStatus {
  UNVERIFIED
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum DesignStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  RECEIVED
  PROCESSING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  UNDELIVERED_1
  UNDELIVERED_2
  UNDELIVERED_3
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum PayoutMethodType {
  UPI
  BANK_ACCOUNT
}

enum PayoutVerificationStatus {
  DRAFT
  PENDING_PROVIDER
  PENDING_REVIEW
  VERIFIED
  REJECTED
  REQUIRES_RESUBMISSION
  DISABLED
}

enum PayoutReviewAction {
  APPROVED
  REJECTED
  REQUIRES_RESUBMISSION
}

enum ArtistSettlementStatus {
  PENDING
  APPROVED
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum ReturnClaimReason {
  DAMAGED_GOODS
  WRONG_PRODUCT
  WRONG_SIZE
  WRONG_COLOR
  OTHER_ELIGIBLE_ISSUE
}

enum ReturnClaimStatus {
  OPEN
  UNDER_REVIEW
  APPROVED
  REJECTED
  REFUNDED
}

model GlobalColor {
  id                 String    @id @default(uuid())
  name               String    @unique
  hex                String
  mockupUrl          String
  fileKey            String
  shadowMapUrl       String?
  shadowMapKey       String?
  displacementMapUrl String?
  displacementMapKey String?
  backMockupUrl      String?
  backFileKey        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  products           Product[]
}

model Review {
  id            String   @id @default(uuid())
  orderId       String
  productId     String
  customerId    String
  artistId      String
  productRating Int
  artistRating  Int
  feedback      String?
  createdAt     DateTime @default(now())

  order    Order   @relation(fields: [orderId], references: [id])
  product  Product @relation(fields: [productId], references: [id])
  customer User    @relation("CustomerReviews", fields: [customerId], references: [id])
  artist   User    @relation("ArtistReviews", fields: [artistId], references: [id])

  @@unique([orderId, productId])
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime @default(now())
  admin        User     @relation("AdminAuditLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
}
