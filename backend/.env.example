# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/teehive?schema=public"

# Authentication Secrets
JWT_SECRET="generate-a-secure-random-string"
ACCESS_TOKEN_SECRET="generate-a-long-secret-key"
REFRESH_TOKEN_SECRET="generate-another-long-secret-key"

# Cloudflare R2 Storage
R2_ACCESS_KEY="your-r2-access-key"
R2_SECRET_KEY="your-r2-secret-key"
R2_BUCKET_NAME="teehive-assets"
R2_ENDPOINT="your-cloudflare-r2-endpoint"
R2_PUBLIC_URL="your-public-r2-assets-url"

# Payment Integration (Razorpay)
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"
RAZORPAYX_KEY_ID="rzp_live_x_..."
RAZORPAYX_KEY_SECRET="your-razorpayx-secret"
RAZORPAYX_SOURCE_ACCOUNT_NUMBER="your-razorpayx-customer-identifier-or-source-account"
# When true, skip RazorpayX API validation; payout methods are still saved and marked verified on file (no admin approval step).
DISABLE_RAZORPAYX_VALIDATION="false"
PAYOUT_DETAILS_ENCRYPTION_KEY="a-long-random-secret-used-to-encrypt-payout-data"

# Email Integration (Postmark)
POSTMARK_SERVER_TOKEN="your-postmark-token"
POSTMARK_FROM_EMAIL="support@teehive.com"
ADMIN_EMAIL="admin@teehive.com"

# App Settings
PORT=3000
FRONTEND_URL="http://localhost:5173"
# Production: optional comma-separated list for CORS (overrides www/apex auto-pair from FRONTEND_URL).
# FRONTEND_URLS="https://teehive.co.in,https://www.teehive.co.in"
NODE_ENV="development"
