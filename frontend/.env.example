# Leave empty in local dev: the app calls /api on the Vite dev server, which proxies to the backend.
# Default proxy target is http://127.0.0.1:3000 (IPv4 avoids localhost → ::1 ECONNREFUSED with some Node/Express setups).
# VITE_API_URL=
# Optional override:
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000

VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
